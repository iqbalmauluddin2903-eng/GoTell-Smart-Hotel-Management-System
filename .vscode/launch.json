{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run C++ (External Terminal)",
            "type": "cppdbg",
            "request": "launch",
            "program": "C:\\Windows\\System32\\cmd.exe",
            "args": [
                "/k",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "cwd": "${fileDirname}",
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "gdb",
            "preLaunchTask": "compile"
        }
    ]
}